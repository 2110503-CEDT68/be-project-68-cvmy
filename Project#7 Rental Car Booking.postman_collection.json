          "name": "1. User ทั่วไปลงทะเบียน (Registration + Validation)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"USER_EMAIL\", \"user_\" + Date.now() + \"@gmail.com\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 (Registered)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if(pm.response.code === 200) {",
                  "    pm.collectionVariables.set(\"TOKEN\", pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
